# Copy to `.env` for local dev, and set the same two vars in Netlify
# (Site configuration → Environment variables). Both are safe for the
# frontend — the publishable/anon key is guarded by row-level security.
#
# Leave these unset and the app runs on its bundled sample data.

VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_your_key_here
